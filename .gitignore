# =============================================================================
# Project-specific
# =============================================================================

# Datasets are large and live on Drive / cloud storage, not in git.
data/raw/
data/processed/
data/cache/
data/patches/
data/masks/
data/predictions/
data/splits/
data/scalers/

# Trained model checkpoints are too large for git. Distribute via
# Hugging Face Hub or release artifacts.
*.pt
*.pth
*.ckpt
*.safetensors

# HDF5 / parquet / numpy / netCDF data files
*.h5
*.hdf5
*.parquet
*.npz
*.npy
*.nc

# Generated figure outputs are tracked in figures/publication/ explicitly,
# but anything dumped into figures/output/ or figures/03b/ is ephemeral.
figures/output/
figures/03b/

# Deprecated folders / files pending manual removal
_DEPRECATED_*
*.deprecated
__test_marker__*
.gitignored_testfile

# =============================================================================
# Python
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# C extensions
*.so

